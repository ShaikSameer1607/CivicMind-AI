rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /evidence/{userId}/{issueId}/{mediaType}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 52 * 1024 * 1024
        && (
          (mediaType == 'images' && request.resource.contentType.matches('image/.*'))
          || (mediaType == 'videos' && request.resource.contentType.matches('video/.*'))
          || (mediaType == 'audio' && request.resource.contentType.matches('audio/.*'))
        );
    }
  }
}
